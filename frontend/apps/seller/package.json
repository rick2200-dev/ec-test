    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@tailwindcss/postcss": "^4",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "typescript": "^6.0.2",
