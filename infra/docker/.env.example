# Database
DATABASE_URL=postgres://ecmarket:localdev@localhost:5432/ecmarket_dev?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Pub/Sub Emulator
PUBSUB_EMULATOR_HOST=localhost:8085
PUBSUB_PROJECT_ID=ec-marketplace-dev

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.ecmarket.example.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Vertex AI (disabled for local dev)
VERTEX_AI_ENABLED=false
GCP_PROJECT_ID=your-gcp-project

# RBAC (auth service <-> gateway internal authz)
# Shared secret used by the gateway to call auth service /internal/authz/*.
# Must be identical on both sides; gateway sends it as X-Internal-Token.
AUTH_INTERNAL_TOKEN=change-me-internal-token

# First-run super_admin bootstrap. If both are set on auth service startup
# and no super_admin exists yet for the tenant, the user identified by
# AUTH_BOOTSTRAP_SUPERADMIN_SUB (an Auth0 sub) is granted super_admin.
# Idempotent: a no-op once any super_admin exists.
AUTH_BOOTSTRAP_SUPERADMIN_SUB=
AUTH_BOOTSTRAP_TENANT_ID=
